# ===========================================
# Eagle E-Commerce Platform - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
# ===========================================

# ===========================================
# 🔐 Payload CMS Configuration
# ===========================================
# Generate a secure secret: openssl rand -hex 32
PAYLOAD_SECRET=your_payload_secret_here

# ===========================================
# 💾 Database Configuration
# ===========================================
# SQLite database path (file-based database)
DATABASE_URI=file:./payload.db

# Optional: Disable automatic DB schema push in production
# Set to '1' to disable, leave empty or unset to enable
DISABLE_DB_PUSH=

# ===========================================
# 🌐 Server & Domain Configuration
# ===========================================
# Your production domain (with https://)
# For testing without domain: http://YOUR_DROPLET_IP:3000
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# ===========================================
# 💳 Paystack Payment Gateway
# ===========================================
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
# Use live keys for production, test keys for staging
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# ===========================================
# 📧 Resend Email Service
# ===========================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Optional: Default "from" email address
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# 🚀 Performance & Telemetry
# ===========================================
# Disable Next.js telemetry (recommended for production)
NEXT_TELEMETRY_DISABLED=1

# Optional: Memory limit for Node.js (in bytes)
# For 1GB RAM droplets: 1073741824 (1GB) or 536874182 (512MB)
# NODE_OPTIONS=--max-old-space-size=1024

# ===========================================
# 🔒 Security (Optional)
# ===========================================
# Cookie secure flag (set to true in production with HTTPS)
# NEXT_PUBLIC_COOKIE_SECURE=true

# ===========================================
# 📊 Logging (Optional)
# ===========================================
# Log level: debug, info, warn, error
# LOG_LEVEL=info

# ===========================================
# 🎨 Feature Flags (Optional)
# ===========================================
# Enable/disable specific features
# ENABLE_NEWSLETTER=true
# ENABLE_REVIEWS=true
# ENABLE_AMBASSADOR_PROGRAM=true
